{
  "name": "hllc-store-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --filter \"@hllc/shared\" build && pnpm --parallel --filter \"./apps/*\" build",
    "lint": "pnpm --parallel --filter \"./apps/*\" lint"
  }
}
