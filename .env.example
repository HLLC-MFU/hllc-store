MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=hllc_store
PORT=3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_USERNAME=adminae
ADMIN_PASSWORD=admin12315
# Prefer ADMIN_PASSWORD_HASH in production. Generate with:
# node -e "const {scryptSync,randomBytes}=require('crypto');const p='your-password';const s=randomBytes(16).toString('base64url');console.log(`scrypt:${s}:${scryptSync(p,s,64).toString('base64url')}`)"
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# Gmail without App Password: use OAuth2 for the same Gmail sender account.
GMAIL_USER=your-email@gmail.com
GMAIL_OAUTH_CLIENT_ID=your-google-oauth-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token

# Recommended: use an SMTP provider such as Brevo, SendGrid, Mailgun, Zoho, or your hosting email.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password-or-api-key
SMTP_FROM=store@example.com

# Optional fallback: Gmail requires a Gmail App Password, not your normal Gmail password.
GMAIL_APP_PASSWORD=your-gmail-app-password
